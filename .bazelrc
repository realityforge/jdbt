common --java_language_version=17
common --java_runtime_version=remotejdk_17
common --tool_java_language_version=17
common --tool_java_runtime_version=remotejdk_17

build --nojava_header_compilation
build --experimental_strict_java_deps=error
test --explicit_java_test_deps

# Generate the symlink tree as a peer directory
# If we generate in the current directory, IDEA can start scanning an ultimately get locked up or crash
common --symlink_prefix=../.bazel/jdbt/

# # Try and import a user specific configuration
try-import %workspace%/user.bazelrc
